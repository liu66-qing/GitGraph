# === LLM Configuration (DeepSeek / OpenAI-compatible) ===
LLM_API_KEY=sk-your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_ID=deepseek-chat

# === Embedding (DashScope / OpenAI-compatible) ===
EMBED_MODEL_TYPE=dashscope
EMBED_MODEL_NAME=text-embedding-v3
EMBED_API_KEY=sk-your-dashscope-key
EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBED_DIMENSIONS=1024

# === Neo4j ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=evograph123
NEO4J_DATABASE=neo4j

# === PostgreSQL ===
DATABASE_URL=postgresql+asyncpg://evograph:evograph123@localhost:5432/evograph

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Qdrant (Cloud or Local) ===
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=evograph_chunks
QDRANT_VECTOR_SIZE=1024
QDRANT_DISTANCE=cosine
QDRANT_TIMEOUT=30

# === Application ===
APP_NAME=EvoGraph
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8080
SECRET_KEY=change-me-in-production

# === Celery ===
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
